---
export const prerender = false;

import AdminShell from "@/components/admin/AdminShell.astro";
import { adminCookieName, getAdminBySessionToken } from "@/lib/admin/auth";
import { handleSudoVerification } from "@/lib/admin/page-helpers";
import {
  deleteCmsEntry,
  getActiveSessions,
  getAllCmsEntries,
  getAllSettings,
  getDailyPublicViews,
  getMonitoringSummary,
  getRecentMonitoringEvents,
  logAdminEvent,
  upsertCmsEntry,
  upsertSetting,
} from "@/lib/admin/repository";
import { formatDayLong, formatDateTime, formatEventType, formatSettingKey, renderCmsPreview } from "@/lib/admin/view-formatters";
import { queryRows } from "@/lib/admin/db";

const sessionToken = Astro.cookies.get(adminCookieName)?.value;
if (!sessionToken) {
  return Astro.redirect(import.meta.env.BASE_URL + "kall-control-panel/login");
}

const currentAdmin = await getAdminBySessionToken(sessionToken);
if (!currentAdmin) {
  Astro.cookies.delete(adminCookieName, { path: "/" });
  return Astro.redirect(import.meta.env.BASE_URL + "kall-control-panel/login");
}

let noticeMessage = "";
let errorMessage = "";

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const action = String(formData.get("action") ?? "");

  try {
    await handleSudoVerification(Astro, currentAdmin.username, formData);

    if (action === "save-setting") {
      const key = String(formData.get("setting_key") ?? "").trim();
      const value = String(formData.get("setting_value") ?? "").trim();
      const valueTypeRaw = String(formData.get("value_type") ?? "string").trim();
      const allowedTypes = ["string", "number", "boolean", "json"] as const;
      const valueType = allowedTypes.includes(valueTypeRaw as (typeof allowedTypes)[number])
        ? (valueTypeRaw as (typeof allowedTypes)[number])
        : "string";

      if (!key) {
        throw new Error("Setting key wajib diisi.");
      }

      if (valueType === "json") {
        JSON.parse(value || "{}");
      }

      await upsertSetting(key, value, valueType, currentAdmin.id);
      await logAdminEvent(
        "setting_updated",
        "admin-panel",
        `Setting ${key} disimpan oleh ${currentAdmin.username}`,
        "info",
        { key, valueType },
        currentAdmin.id
      );
      noticeMessage = "Setting berhasil disimpan.";
    } else if (action === "save-cms") {
      const slug = String(formData.get("slug") ?? "").trim().toLowerCase();
      const title = String(formData.get("title") ?? "").trim();
      const contentJson = String(formData.get("content_json") ?? "").trim();
      const isPublished = formData.get("is_published") === "on";

      if (!slug || !title) {
        throw new Error("Slug dan title CMS wajib diisi.");
      }

      JSON.parse(contentJson || "{}");

      await upsertCmsEntry(slug, title, contentJson, isPublished, currentAdmin.id);
      await logAdminEvent(
        "cms_saved",
        "admin-panel",
        `CMS ${slug} disimpan oleh ${currentAdmin.username}`,
        "info",
        { slug, isPublished },
        currentAdmin.id
      );
      noticeMessage = "CMS entry berhasil disimpan.";
    } else if (action === "delete-cms") {
      const cmsId = Number(formData.get("cms_id") ?? "0");
      if (!Number.isFinite(cmsId) || cmsId <= 0) {
        throw new Error("ID CMS tidak valid.");
      }

      await deleteCmsEntry(cmsId);
      await logAdminEvent(
        "cms_deleted",
        "admin-panel",
        `CMS ID ${cmsId} dihapus oleh ${currentAdmin.username}`,
        "warning",
        { cmsId },
        currentAdmin.id
      );
      noticeMessage = "CMS entry berhasil dihapus.";
    } else if (action === "write-note") {
      const note = String(formData.get("monitoring_note") ?? "").trim();
      if (!note) {
        throw new Error("Catatan monitoring tidak boleh kosong.");
      }

      await logAdminEvent(
        "manual_monitoring_note",
        "admin-panel",
        note,
        "info",
        null,
        currentAdmin.id
      );
      noticeMessage = "Catatan monitoring tersimpan.";
    }
  } catch (error) {
    errorMessage = error instanceof Error ? error.message : "Terjadi kesalahan tak terduga.";
    await logAdminEvent(
      "admin_action_failed",
      "admin-panel",
      `Aksi admin gagal: ${errorMessage}`,
      "error",
      { action },
      currentAdmin.id
    );
  }
}

const [settings, cmsEntries, summary, events, sessions, dailyViewsRaw, onlineUsersCount] = await Promise.all([
  getAllSettings(),
  getAllCmsEntries(),
  getMonitoringSummary(),
  getRecentMonitoringEvents(25),
  getActiveSessions(25),
  getDailyPublicViews(14),
  queryRows<any[]>(
    `
      SELECT COUNT(DISTINCT payload_json->>'$.ip') AS total
      FROM monitoring_events
      WHERE event_type IN ('public_page_view', 'public_heartbeat')
        AND created_at >= UTC_TIMESTAMP() - INTERVAL 40 SECOND
    `
  ),
]);

const initialActiveOnline = onlineUsersCount[0]?.total ?? 0;

const publishedEntries = cmsEntries.filter((entry) => entry.is_published === 1);
const publicSettings = settings.filter((setting) => {
  return (
    setting.setting_key.startsWith("site_") ||
    setting.setting_key.startsWith("public_") ||
    setting.setting_key === "maintenance_mode" ||
    setting.setting_key === "analytics_enabled"
  );
});

const viewsByDate = new Map(dailyViewsRaw.map((item) => [item.view_date, Number(item.total_views) || 0]));
const dayWindow = 14;
const filledDailyViews = Array.from({ length: dayWindow }, (_, index) => {
  const date = new Date();
  date.setUTCHours(0, 0, 0, 0);
  date.setUTCDate(date.getUTCDate() - (dayWindow - 1 - index));
  const key = date.toISOString().slice(0, 10);

  return {
    view_date: key,
    total_views: viewsByDate.get(key) ?? 0,
  };
});

const todayViews = filledDailyViews[filledDailyViews.length - 1]?.total_views ?? 0;

const compactDailyViews = filledDailyViews.slice(-7);
const totalViews7 = compactDailyViews.reduce((acc, item) => acc + item.total_views, 0);
const topViewDay7 = [...compactDailyViews].sort((a, b) => b.total_views - a.total_views)[0] ?? {
  view_date: "-",
  total_views: 0,
};
const previousDayViews = compactDailyViews[compactDailyViews.length - 2]?.total_views ?? 0;
const viewDeltaLabel =
  previousDayViews === 0
    ? todayViews > 0
      ? "+100%"
      : "0%"
    : `${Math.round(((todayViews - previousDayViews) / previousDayViews) * 100)}%`;

// Initial bootstrap data for the hybrid real-time view chart (29 minutes + 60 seconds)
const initialRecentViews = [
  ...Array.from({ length: 29 }, (_, index) => {
    return {
      label: `-${29 - index}m`,
      total_views: 0,
    };
  }),
  ...Array.from({ length: 60 }, (_, index) => {
    return {
      label: `${index}s`,
      total_views: 0,
    };
  }),
];


const quickPublishedEntries = [...publishedEntries]
  .sort((a, b) => new Date(b.updated_at).getTime() - new Date(a.updated_at).getTime())
  .slice(0, 6);
const quickEvents = events.slice(0, 6);
const draftEntriesCount = Math.max(cmsEntries.length - publishedEntries.length, 0);
---

<AdminShell
  currentAdmin={currentAdmin}
  pageTitle="Dashboard Monitoring"
  pageDescription="Fokus utama: insight traffic views harian dan konten yang sedang live di web public."
  activePath={import.meta.env.BASE_URL + "kall-control-panel"}
  noticeMessage={noticeMessage}
  errorMessage={errorMessage}
>

        <section id="monitoring-views" class="section">
          <h3>Monitoring Views Per Hari</h3>
          <p class="sub">Ringkasan secukupnya untuk pantau trafik, sisanya fokus ke fungsi dashboard utama.</p>

          <div class="metric-grid">
            <article class="metric-card">
              <p class="label">Views Hari Ini</p>
              <p class="value" id="stat-today-views">{todayViews}</p>
              <p class="muted" id="stat-views-delta" style="margin:4px 0 0;">Perubahan dari kemarin: {viewDeltaLabel}</p>
            </article>
            <article class="metric-card">
              <p class="label">Total Views (7 Hari)</p>
              <p class="value" id="stat-total-7d-views">{totalViews7}</p>
            </article>
            <article class="metric-card live-card" style="border: 1px solid var(--sec); background: color-mix(in srgb, var(--sec) 8%, var(--component-bg));">
              <p class="label" style="display: flex; align-items: center; gap: 6px; margin: 0; color: var(--white-icon);">
                <span class="pulse-dot"></span>
                Online Sekarang
              </p>
              <p class="value" id="stat-online-users" style="color: var(--white);">{initialActiveOnline}</p>
              <p class="muted" style="margin:4px 0 0; color: var(--white-icon);">Pengunjung aktif saat ini</p>
            </article>
            <article class="metric-card">
              <p class="label">Puncak 7 Hari</p>
              <p class="value" id="stat-peak-views">{topViewDay7.total_views}</p>
              <p class="muted" id="stat-peak-date" style="margin:4px 0 0;">{formatDayLong(topViewDay7.view_date)}</p>
            </article>
          </div>

          <div class="split">
            <div class="panel">
               <div class="panel-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                <h4 id="trend-title" style="margin: 0; font-size: 15px; font-weight: 800;">Real-time View (Hybrid 30m)</h4>
                <div class="trend-switch" style="display: flex; gap: 4px; background: var(--container); padding: 4px; border-radius: 8px; border: 1px solid var(--border-subtle);">
                  <button type="button" id="btn-trend-daily" style="padding: 4px 8px; font-size: 11px; font-weight: 700; border-radius: 6px; border: 0; cursor: pointer; transition: all 0.2s; background: transparent; color: var(--white-icon);">Harian (7 Hari)</button>
                  <button type="button" id="btn-trend-hourly" class="active" style="padding: 4px 8px; font-size: 11px; font-weight: 700; border-radius: 6px; border: 0; cursor: pointer; transition: all 0.2s; background: linear-gradient(90deg, var(--sec), var(--pink)); color: #fff;">Real-time (30 Menit)</button>
                </div>
              </div>
              <p id="trend-desc">Grafik views 30 menit terakhir: 1 menit pertama per detik, sisanya per menit.</p>

              <!-- Dynamic Area (Hill) Chart -->
              <div class="chart-container" style="position: relative; height: 180px; width: 100%; margin-top: 16px;">
                <canvas 
                  id="live-views-chart"
                  data-daily={JSON.stringify(compactDailyViews)}
                  data-hourly={JSON.stringify(initialRecentViews)}
                ></canvas>
              </div>
            </div>

            <div class="panel">
              <h4>Ringkasan Dashboard Utama</h4>
              <p>Fokus utama operasional konten dan health dashboard.</p>

              <div class="quick-summary">
                <div class="quick-item">
                  <p class="label">Konten Published</p>
                  <p class="value" id="stat-summary-published">{publishedEntries.length}</p>
                </div>
                <div class="quick-item">
                  <p class="label">Konten Draft</p>
                  <p class="value" id="stat-summary-draft">{draftEntriesCount}</p>
                </div>
                <div class="quick-item">
                  <p class="label">Settings Aktif</p>
                  <p class="value" id="stat-summary-settings">{summary.totalSettings}</p>
                </div>
                <div class="quick-item">
                  <p class="label">Sesi Aktif</p>
                  <p class="value" id="stat-summary-sessions">{summary.activeSessions}</p>
                </div>
              </div>

              <ul class="quick-list">
                <li>
                  <strong>Konten terbaru:</strong>
                  {quickPublishedEntries[0] ? ` ${quickPublishedEntries[0].title}` : " belum ada konten published."}
                </li>
                <li>
                  <strong>Aktivitas terbaru:</strong>
                  {quickEvents[0]
                    ? ` ${formatEventType(quickEvents[0].event_type)} (${formatDateTime(quickEvents[0].created_at)})`
                    : " belum ada aktivitas."}
                </li>
              </ul>
            </div>
          </div>
        </section>

        <section id="monitoring-content" class="section">
          <h3>Monitoring Konten Web Public</h3>
          <p class="sub">Lihat konten yang dipublish ke web public plus setting global yang memengaruhi tampilan situs.</p>

          <div class="metric-grid">
            <article class="metric-card">
              <p class="label">Konten Published</p>
              <p class="value">{publishedEntries.length}</p>
            </article>
            <article class="metric-card">
              <p class="label">Total CMS Pages</p>
              <p class="value">{summary.totalCmsPages}</p>
            </article>
            <article class="metric-card">
              <p class="label">Public Settings</p>
              <p class="value">{publicSettings.length}</p>
            </article>
            <article class="metric-card">
              <p class="label">Total Events</p>
              <p class="value">{summary.totalEvents}</p>
            </article>
          </div>

          <div class="split">
            <div class="panel">
              <h4>Daftar Konten Published</h4>
              <p>Data ini mewakili payload CMS yang kemungkinan tampil di website public.</p>

              <div class="tableWrap">
                <table>
                  <thead>
                    <tr>
                      <th>Bagian (Section)</th>
                      <th>Title</th>
                      <th>Konten Preview</th>
                      <th>Updated</th>
                    </tr>
                  </thead>
                  <tbody>
                    {publishedEntries.length === 0 ? (
                      <tr>
                        <td colspan="4" class="muted">Belum ada konten published.</td>
                      </tr>
                    ) : (
                      publishedEntries.map((entry) => (
                        <tr>
                          <td style="font-weight: 600; color: var(--white);">{formatSettingKey(entry.slug)}</td>
                          <td>{entry.title}</td>
                          <td style="white-space: pre-line; font-size: 13px; line-height: 1.5; color: var(--white-icon);">
                            {renderCmsPreview(entry.content_json)}
                          </td>
                          <td>{formatDateTime(entry.updated_at)}</td>
                        </tr>
                      ))
                    )}
                  </tbody>
                </table>
              </div>
            </div>

            <div class="panel">
              <h4>Public Settings Snapshot</h4>
              <p>Setting ini biasanya terpakai langsung oleh layer web public.</p>

              <div class="tableWrap">
                <table>
                  <thead>
                    <tr>
                      <th>Nama Setting</th>
                      <th>Value</th>
                    </tr>
                  </thead>
                  <tbody>
                    {publicSettings.length === 0 ? (
                      <tr>
                        <td colspan="2" class="muted">Tidak ada setting public terdeteksi.</td>
                      </tr>
                    ) : (
                      publicSettings.map((setting) => (
                        <tr>
                          <td style="font-weight: 600; color: var(--white);">{formatSettingKey(setting.setting_key)}</td>
                          <td>{setting.setting_value}</td>
                        </tr>
                      ))
                    )}
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </section>

        <section class="manager-grid">
          <div id="settings-manager" class="section">
            <h3>Website Settings (MySQL)</h3>
            <p class="sub">Tambah atau ubah key-value setting website dari panel admin.</p>

            <form method="post">
              <input type="hidden" name="action" value="save-setting" />
              <div class="form-grid">
                <div class="form-group">
                  <label for="setting_key">Nama Setting</label>
                  <input id="setting_key" name="setting_key" placeholder="Contoh: site_title" required />
                </div>
                <div class="form-group">
                  <label for="value_type">Tipe Data</label>
                  <select id="value_type" name="value_type">
                    <option value="string">Teks (string)</option>
                    <option value="number">Angka (number)</option>
                    <option value="boolean">Ya/Tidak (boolean)</option>
                    <option value="json">JSON (objek)</option>
                  </select>
                </div>
                <div class="form-group full">
                  <label for="setting_value">Nilai Setting</label>
                  <textarea id="setting_value" name="setting_value" placeholder='Contoh nilai JSON: {"heroTitle":"Hello"}' required></textarea>
                </div>
              </div>
              <div class="actions">
                <button type="submit">Simpan Setting</button>
              </div>
            </form>

            <div class="tableWrap">
              <table>
                <thead>
                  <tr>
                    <th>Nama Setting</th>
                    <th>Value</th>
                    <th>Updated</th>
                    <th>Aksi</th>
                  </tr>
                </thead>
                <tbody>
                  {settings.length === 0 ? (
                    <tr>
                      <td colspan="4" class="muted">Belum ada setting tersimpan.</td>
                    </tr>
                  ) : (
                    settings.map((setting) => (
                      <tr>
                        <td style="font-weight: 600; color: var(--white);">{formatSettingKey(setting.setting_key)}</td>
                        <td>{setting.setting_value}</td>
                        <td>{formatDateTime(setting.updated_at)}</td>
                        <td>
                          <div class="action-wrap">
                            <button type="button" class="kebab-btn" aria-label="Aksi">⋮</button>
                            <div class="kebab-dropdown">
                              <button
                                type="button"
                                class="kebab-item edit-setting-btn"
                                data-key={setting.setting_key}
                                data-type={setting.value_type}
                                data-value={setting.setting_value}
                              >Edit</button>
                            </div>
                          </div>
                        </td>
                      </tr>
                    ))
                  )}
                </tbody>
              </table>
            </div>
          </div>

          <div id="cms-manager" class="section">
            <h3>CMS Pages (MySQL)</h3>
            <p class="sub">Kelola konten CMS section website lewat payload JSON.</p>

            <form method="post" id="cms-form">
              <input type="hidden" name="action" value="save-cms" />
              <textarea id="content_json" name="content_json" style="display:none;"></textarea>
              <div class="form-grid">
                <div class="form-group">
                  <label for="slug">Identifikasi Halaman (Slug)</label>
                  <input id="slug" name="slug" placeholder="Contoh: home-hero" required />
                </div>
                <div class="form-group">
                  <label for="title">Judul Halaman</label>
                  <input id="title" name="title" placeholder="Contoh: Homepage Hero Content" required />
                </div>
                <div class="form-group full">
                  <label>Isi Konten</label>
                  <div id="cms-fields-container" style="display: grid; gap: 8px; margin-top: 4px;"></div>
                  <button
                    type="button"
                    id="cms-add-field"
                    style="margin-top: 8px; background: color-mix(in srgb, var(--sec) 15%, transparent); border: 1px dashed var(--sec); color: var(--sec); font-size: 12px; padding: 8px 14px; border-radius: 8px; cursor: pointer;"
                  >
                    + Tambah Field
                  </button>
                </div>
                <div class="form-group full" style="flex-direction: row; align-items: center;">
                  <input id="is_published" name="is_published" type="checkbox" checked style="width:auto; margin:0;" />
                  <label for="is_published" style="margin:0;">Publikasikan halaman ini</label>
                </div>
              </div>
              <div class="actions">
                <button type="submit">Simpan CMS Entry</button>
              </div>
            </form>

            <div class="tableWrap">
              <table>
                <thead>
                  <tr>
                    <th>Bagian (Section)</th>
                    <th>Title</th>
                    <th>Status</th>
                    <th>Updated</th>
                    <th>Aksi</th>
                  </tr>
                </thead>
                <tbody>
                  {cmsEntries.length === 0 ? (
                    <tr>
                      <td colspan="5" class="muted">Belum ada CMS page tersimpan.</td>
                    </tr>
                  ) : (
                    cmsEntries.map((entry) => (
                      <tr>
                        <td style="font-weight: 600; color: var(--white);">{formatSettingKey(entry.slug)}</td>
                        <td>{entry.title}</td>
                        <td>
                          <span class="badge">{entry.is_published === 1 ? "Published" : "Draft"}</span>
                        </td>
                        <td>{formatDateTime(entry.updated_at)}</td>
                        <td><div style="display: flex; gap: 8px; align-items: center;">
                          <div class="action-wrap">
                            <button type="button" class="kebab-btn" aria-label="Aksi">⋮</button>
                            <div class="kebab-dropdown">
                              <button
                                type="button"
                                class="kebab-item edit-cms-btn"
                                data-slug={entry.slug}
                                data-title={entry.title}
                                data-content={entry.content_json}
                                data-published={entry.is_published}
                              >Edit</button>
                              <form method="post" onsubmit="return confirm('Hapus CMS entry ini?');" style="margin:0;">
                                <input type="hidden" name="action" value="delete-cms" />
                                <input type="hidden" name="cms_id" value={entry.id} />
                                <button class="kebab-item danger-item" type="submit">Hapus</button>
                              </form>
                            </div>
                          </div>
                        </div></td>
                      </tr>
                    ))
                  )}
                </tbody>
              </table>
            </div>
          </div>
        </section>

        <section id="monitoring-events" class="section">
          <h3>Monitoring Events</h3>
          <p class="sub">Catatan operasional dari login, update CMS/setting, dan aktivitas admin.</p>

          <form method="post" style="margin-top: 10px;">
            <input type="hidden" name="action" value="write-note" />
            <div class="form-group">
              <label for="monitoring_note">Tambah Catatan Monitoring Manual</label>
              <textarea id="monitoring_note" name="monitoring_note" placeholder="Contoh: Perubahan konten homepage untuk campaign April" required></textarea>
            </div>
            <div class="actions">
              <button type="submit">Simpan Catatan</button>
            </div>
          </form>

          <div class="tableWrap">
            <table>
              <thead>
                <tr>
                  <th>Waktu</th>
                  <th>Type</th>
                  <th>Level</th>
                  <th>Message</th>
                </tr>
              </thead>
              <tbody>
                {events.length === 0 ? (
                  <tr>
                    <td colspan="4" class="muted">Belum ada event monitoring.</td>
                  </tr>
                ) : (
                  events.map((event) => (
                    <tr>
                      <td>{formatDateTime(event.created_at)}</td>
                      <td>{formatEventType(event.event_type)}</td>
                      <td>{event.level}</td>
                      <td>{event.message}</td>
                    </tr>
                  ))
                )}
              </tbody>
            </table>
          </div>
        </section>

        <section id="active-sessions" class="section">
          <h3>Active Admin Sessions</h3>
          <p class="sub">Pantau sesi login superadmin aktif dari browser atau IP berbeda.</p>

          <div class="tableWrap">
            <table>
              <thead>
                <tr>
                  <th>Admin</th>
                  <th>IP</th>
                  <th>User Agent</th>
                  <th>Last Seen</th>
                  <th>Expires</th>
                </tr>
              </thead>
              <tbody>
                {sessions.length === 0 ? (
                  <tr>
                    <td colspan="5" class="muted">Tidak ada sesi aktif.</td>
                  </tr>
                ) : (
                  sessions.map((session) => (
                    <tr>
                      <td>
                        <strong>{session.username}</strong>
                        <div class="muted">{session.role}</div>
                      </td>
                      <td>{session.ip_address}</td>
                      <td>{session.user_agent}</td>
                      <td>{formatDateTime(session.last_seen_at)}</td>
                      <td>{formatDateTime(session.expires_at)}</td>
                    </tr>
                  ))
                )}
              </tbody>
            </table>
          </div>
        </section>
</AdminShell>

<style>
  /* Pulse animation for live visitor dot */
  .pulse-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #10b981;
    box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
    animation: pulse 1.5s infinite;
    vertical-align: middle;
  }
  @keyframes pulse {
    0% {
      transform: scale(0.95);
      box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
    }
    70% {
      transform: scale(1);
      box-shadow: 0 0 0 6px rgba(16, 185, 129, 0);
    }
    100% {
      transform: scale(0.95);
      box-shadow: 0 0 0 0 rgba(16, 185, 129, 0);
    }
  }
  .live-card {
    transition: all 0.3s ease;
  }
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js" is:inline></script>

<script>
  // CMS Edit Pre-fill — key-value field builder
  function cmsAddField(key = "", value = "") {
    const container = document.getElementById("cms-fields-container");
    if (!container) return;
    const row = document.createElement("div");
    row.style.cssText = "display: grid; grid-template-columns: 1fr 1fr auto; gap: 8px; align-items: center;";
    row.innerHTML = `
      <input type="text" placeholder="Nama field (contoh: headline)" value="${key.replace(/"/g, '&quot;')}" class="cms-field-key" style="border-radius: 10px; border: 1px solid var(--border-subtle); background: color-mix(in srgb, var(--background) 70%, transparent); color: var(--white); padding: 10px 12px; font: inherit; font-size: 13px; outline: none;" />
      <input type="text" placeholder="Nilai" value="${value.replace(/"/g, '&quot;')}" class="cms-field-val" style="border-radius: 10px; border: 1px solid var(--border-subtle); background: color-mix(in srgb, var(--background) 70%, transparent); color: var(--white); padding: 10px 12px; font: inherit; font-size: 13px; outline: none;" />
      <button type="button" title="Hapus field" style="background: rgba(255,89,123,0.15); border: 1px solid rgba(255,89,123,0.4); color: #ff788a; border-radius: 8px; padding: 8px 10px; cursor: pointer; font-size: 13px; line-height: 1;">✕</button>
    `;
    row.querySelector("button")!.addEventListener("click", () => row.remove());
    container.appendChild(row);
  }

  // Start with 2 empty fields by default
  cmsAddField();
  cmsAddField();

  document.getElementById("cms-add-field")?.addEventListener("click", () => cmsAddField());

  // On submit: build JSON from key-value rows
  document.getElementById("cms-form")?.addEventListener("submit", (e) => {
    const keys = document.querySelectorAll(".cms-field-key") as NodeListOf<HTMLInputElement>;
    const vals = document.querySelectorAll(".cms-field-val") as NodeListOf<HTMLInputElement>;
    const obj: Record<string, string> = {};
    keys.forEach((k, i) => {
      const key = k.value.trim();
      if (key) obj[key] = vals[i]?.value ?? "";
    });
    const hidden = document.getElementById("content_json") as HTMLTextAreaElement;
    if (hidden) hidden.value = JSON.stringify(obj);
    if (Object.keys(obj).length === 0) {
      e.preventDefault();
      alert("Tambahkan minimal satu field konten.");
    }
  });

  const editCmsButtons = document.querySelectorAll(".edit-cms-btn");
  const slugInput = document.getElementById("slug") as HTMLInputElement;
  const titleInput = document.getElementById("title") as HTMLInputElement;
  const publishedCheckbox = document.getElementById("is_published") as HTMLInputElement;

  editCmsButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const slug = btn.getAttribute("data-slug") ?? "";
      const title = btn.getAttribute("data-title") ?? "";
      const content = btn.getAttribute("data-content") ?? "{}";
      const published = btn.getAttribute("data-published") === "1";

      if (slugInput) slugInput.value = slug;
      if (titleInput) titleInput.value = title;
      if (publishedCheckbox) publishedCheckbox.checked = published;

      // Clear and repopulate field rows from JSON
      const container = document.getElementById("cms-fields-container");
      if (container) {
        container.innerHTML = "";
        try {
          const parsed = JSON.parse(content);
          const entries = Object.entries(parsed);
          if (entries.length === 0) {
            cmsAddField(); cmsAddField();
          } else {
            entries.forEach(([k, v]) => cmsAddField(k, String(v)));
          }
        } catch {
          cmsAddField(); cmsAddField();
        }
      }

      slugInput?.scrollIntoView({ behavior: "smooth", block: "center" });
    });
  });

  // ── Kebab dropdown toggle ──
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    const trigger = target.closest(".kebab-btn");
    const wrap = target.closest(".action-wrap");

    // Close all open dropdowns first
    document.querySelectorAll(".action-wrap.open").forEach((el) => {
      if (el !== wrap) el.classList.remove("open");
    });

    if (trigger && wrap) {
      wrap.classList.toggle("open");
    }
  });

  // Settings Edit Pre-fill
  const editSettingButtons = document.querySelectorAll(".edit-setting-btn");
  const keyInput = document.getElementById("setting_key") as HTMLInputElement;
  const typeSelect = document.getElementById("value_type") as HTMLSelectElement;
  const valueInput = document.getElementById("setting_value") as HTMLTextAreaElement;

  editSettingButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const key = btn.getAttribute("data-key") ?? "";
      const type = btn.getAttribute("data-type") ?? "string";
      const value = btn.getAttribute("data-value") ?? "";

      if (keyInput) keyInput.value = key;
      if (typeSelect) typeSelect.value = type;
      if (valueInput) valueInput.value = value;

      // Close the dropdown
      btn.closest(".action-wrap")?.classList.remove("open");
      keyInput?.scrollIntoView({ behavior: "smooth", block: "center" });
    });
  });

  // Helper functions for formatting dates on the client side
  function formatDayClient(isoDate: string): string {
    const date = new Date(`${isoDate}T00:00:00Z`);
    if (Number.isNaN(date.getTime())) {
      return isoDate;
    }
    return date.toLocaleDateString("id-ID", {
      day: "2-digit",
      month: "short",
    });
  }

  function formatDayLongClient(isoDate: string): string {
    const date = new Date(`${isoDate}T00:00:00Z`);
    if (Number.isNaN(date.getTime())) {
      return isoDate;
    }
    return date.toLocaleDateString("id-ID", {
      day: "2-digit",
      month: "short",
      year: "numeric",
    });
  }

  // --- Dynamic Area (Hill) Chart Setup using Chart.js ---
  let chartInstance: any = null;
  let activeMode: "daily" | "hourly" = "hourly";
  let dailyData: any[] = [];
  let hourlyData: any[] = [];

  const canvas = document.getElementById("live-views-chart") as HTMLCanvasElement;
  
  if (canvas) {
    try {
      dailyData = JSON.parse(canvas.getAttribute("data-daily") || "[]");
      hourlyData = JSON.parse(canvas.getAttribute("data-hourly") || "[]");
    } catch (e) {
      console.error("Failed to parse initial chart data:", e);
    }
  }

  // Extract color values dynamically from CSS custom properties (light/dark mode support)
  function getChartColors() {
    const style = getComputedStyle(document.documentElement);
    const secColor = style.getPropertyValue('--sec').trim() || '#a476ff';
    const pinkColor = style.getPropertyValue('--pink').trim() || '#b08cff';
    const whiteIcon = style.getPropertyValue('--white-icon').trim() || '#b6bed3';
    const borderSubtle = style.getPropertyValue('--border-subtle').trim() || 'rgba(182, 190, 211, 0.24)';
    
    return { secColor, pinkColor, whiteIcon, borderSubtle };
  }

  function hexToRgba(hex: string, opacity: number): string {
    if (hex.startsWith("#")) {
      const r = parseInt(hex.slice(1, 3), 16);
      const g = parseInt(hex.slice(3, 5), 16);
      const b = parseInt(hex.slice(5, 7), 16);
      return `rgba(${r}, ${g}, ${b}, ${opacity})`;
    }
    if (hex.startsWith("rgba") || hex.startsWith("rgb")) {
      return hex.replace(/[\d\.]+\)$/g, `${opacity})`);
    }
    return `rgba(164, 118, 255, ${opacity})`;
  }

  function createGradient(ctx: CanvasRenderingContext2D, color: string) {
    const gradient = ctx.createLinearGradient(0, 0, 0, 180);
    gradient.addColorStop(0, hexToRgba(color, 0.4));
    gradient.addColorStop(1, hexToRgba(color, 0));
    return gradient;
  }

  function initChart() {
    if (!canvas) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    const { secColor, pinkColor, whiteIcon, borderSubtle } = getChartColors();
    
    const labels = activeMode === "daily" 
      ? dailyData.map(item => formatDayClient(item.view_date))
      : hourlyData.map(item => item.label);
      
    const dataValues = activeMode === "daily"
      ? dailyData.map(item => item.total_views)
      : hourlyData.map(item => item.total_views);

    const gradient = createGradient(ctx, secColor);

    const ChartClass = (window as any).Chart;
    if (!ChartClass) {
      console.error("Chart.js is not loaded yet.");
      return;
    }

    chartInstance = new ChartClass(ctx, {
      type: "line",
      data: {
        labels: labels,
        datasets: [{
          label: "Views",
          data: dataValues,
          fill: true,
          backgroundColor: gradient,
          borderColor: secColor,
          borderWidth: 3,
          tension: 0.4,
          pointBackgroundColor: pinkColor,
          pointBorderColor: secColor,
          pointBorderWidth: 2,
          pointRadius: 4,
          pointHoverRadius: 6,
          pointHoverBackgroundColor: "#fff",
          pointHoverBorderColor: secColor,
          pointHoverBorderWidth: 3,
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            display: false
          },
          tooltip: {
            backgroundColor: "rgba(26, 35, 49, 0.95)",
            titleColor: "#fff",
            titleFont: {
              family: "Montserrat Variable",
              size: 11,
              weight: "bold"
            },
            bodyColor: "#f0f2fc",
            bodyFont: {
              family: "Montserrat Variable",
              size: 13,
              weight: "bold"
            },
            borderColor: borderSubtle,
            borderWidth: 1,
            padding: 10,
            displayColors: false,
            callbacks: {
              label: function(context: any) {
                return `${context.parsed.y} online`;
              }
            }
          }
        },
        scales: {
          x: {
            grid: {
              display: false
            },
            ticks: {
              color: whiteIcon,
              font: {
                family: "Montserrat Variable",
                size: activeMode === "daily" ? 10 : 8
              }
            }
          },
          y: {
            grid: {
              color: borderSubtle
            },
            border: {
              dash: [4, 4]
            },
            ticks: {
              color: whiteIcon,
              font: {
                family: "Montserrat Variable",
                size: 10
              },
              precision: 0
            },
            suggestedMin: 0
          }
        }
      }
    });
  }

  function updateChartData() {
    if (!chartInstance) {
      initChart();
      return;
    }
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    const { secColor, pinkColor, whiteIcon, borderSubtle } = getChartColors();
    const gradient = createGradient(ctx, secColor);

    const labels = activeMode === "daily" 
      ? dailyData.map(item => formatDayClient(item.view_date))
      : hourlyData.map(item => item.label);
      
    const dataValues = activeMode === "daily"
      ? dailyData.map(item => item.total_views)
      : hourlyData.map(item => item.total_views);

    chartInstance.data.labels = labels;
    chartInstance.data.datasets[0].data = dataValues;
    chartInstance.data.datasets[0].borderColor = secColor;
    chartInstance.data.datasets[0].backgroundColor = gradient;
    chartInstance.data.datasets[0].pointBackgroundColor = pinkColor;
    chartInstance.data.datasets[0].pointBorderColor = secColor;
    chartInstance.data.datasets[0].pointHoverBorderColor = secColor;
    
    chartInstance.options.scales.x.ticks.color = whiteIcon;
    chartInstance.options.scales.x.ticks.font.size = activeMode === "daily" ? 10 : 8;
    chartInstance.options.scales.y.ticks.color = whiteIcon;
    chartInstance.options.scales.y.grid.color = borderSubtle;
    chartInstance.options.plugins.tooltip.borderColor = borderSubtle;

    chartInstance.update();
  }

  if (canvas) {
    if ((window as any).Chart) {
      initChart();
    } else {
      document.addEventListener("DOMContentLoaded", () => {
        initChart();
      });
      setTimeout(initChart, 500);
    }
  }

  const themeObserver = new MutationObserver(() => {
    updateChartData();
  });
  themeObserver.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ["data-theme"]
  });

  const btnDaily = document.getElementById("btn-trend-daily");
  const btnHourly = document.getElementById("btn-trend-hourly");
  const trendTitle = document.getElementById("trend-title");
  const trendDesc = document.getElementById("trend-desc");

  if (btnDaily && btnHourly) {
    btnDaily.addEventListener("click", () => {
      activeMode = "daily";
      
      btnDaily.classList.add("active");
      btnDaily.style.background = "linear-gradient(90deg, var(--sec), var(--pink))";
      btnDaily.style.color = "#fff";
      
      btnHourly.classList.remove("active");
      btnHourly.style.background = "transparent";
      btnHourly.style.color = "var(--white-icon)";
      
      if (trendTitle) trendTitle.textContent = "Tren Harian (7 Hari)";
      if (trendDesc) trendDesc.textContent = "Snapshot ringkas total views harian dalam seminggu.";
      
      updateChartData();
    });

    btnHourly.addEventListener("click", () => {
      activeMode = "hourly";
      
      btnHourly.classList.add("active");
      btnHourly.style.background = "linear-gradient(90deg, var(--sec), var(--pink))";
      btnHourly.style.color = "#fff";
      
      btnDaily.classList.remove("active");
      btnDaily.style.background = "transparent";
      btnDaily.style.color = "var(--white-icon)";
      
      if (trendTitle) trendTitle.textContent = "Real-time View (Hybrid 30m)";
      if (trendDesc) trendDesc.textContent = "Grafik views 30 menit terakhir: 1 menit pertama per detik, sisanya per menit.";
      
      updateChartData();
    });
  }

  async function pollLiveStats() {
    try {
      const baseUrl = document.documentElement.getAttribute("data-base-url") || "/";
      const res = await fetch(`${baseUrl}api/admin/live-stats`);
      if (!res.ok) return;
      const data = await res.json();
      if (!data.success) return;

      const statTodayViews = document.getElementById("stat-today-views");
      const statViewsDelta = document.getElementById("stat-views-delta");
      const statTotal7dViews = document.getElementById("stat-total-7d-views");
      const statAvgViews = document.getElementById("stat-avg-views");
      const statPeakViews = document.getElementById("stat-peak-views");
      const statPeakDate = document.getElementById("stat-peak-date");
      const statOnlineUsers = document.getElementById("stat-online-users");

      if (statTodayViews) statTodayViews.textContent = data.metrics.todayViews;
      if (statViewsDelta) statViewsDelta.textContent = `Perubahan dari kemarin: ${data.metrics.viewDeltaLabel}`;
      if (statTotal7dViews) statTotal7dViews.textContent = data.metrics.totalViews7;
      if (statAvgViews) statAvgViews.textContent = data.metrics.averageViews;
      if (statPeakViews) statPeakViews.textContent = data.metrics.topViewDay7.total_views;
      if (statPeakDate) statPeakDate.textContent = formatDayLongClient(data.metrics.topViewDay7.view_date);
      if (statOnlineUsers && typeof data.activeOnline !== "undefined") {
        statOnlineUsers.textContent = data.activeOnline;
      }

      const statSummaryPublished = document.getElementById("stat-summary-published");
      const statSummaryDraft = document.getElementById("stat-summary-draft");
      const statSummarySettings = document.getElementById("stat-summary-settings");
      const statSummarySessions = document.getElementById("stat-summary-sessions");

      if (statSummaryPublished) statSummaryPublished.textContent = data.summary.publishedCount;
      if (statSummaryDraft) statSummaryDraft.textContent = data.summary.draftCount;
      if (statSummarySettings) statSummarySettings.textContent = data.summary.totalSettings;
      if (statSummarySessions) statSummarySessions.textContent = data.summary.activeSessions;

      if (data.dailyViews) {
        dailyData = data.dailyViews;
      }
      
      if (data.recentViews) {
        // Generate the hybrid bins (29 minute-bins + 60 second-bins)
        const clientNow = Date.now();
        const minuteBins = Array.from({ length: 29 }, (_, index) => {
          return {
            label: `-${29 - index}m`,
            total_views: 0
          };
        });
        const secondBins = Array.from({ length: 60 }, (_, index) => {
          const binTime = clientNow - (59 - index) * 1000;
          const binDate = new Date(binTime);
          const secondStr = String(binDate.getSeconds()).padStart(2, '0');
          return {
            timestampMs: binTime,
            label: `${secondStr}s`,
            total_views: 0
          };
        });

        const bins = [...minuteBins, ...secondBins];

        // Parse all events with their timestamps and IP addresses
        const events = data.recentViews.map((evt: any) => {
          let ip = "unknown";
          try {
            const payload = typeof evt.payload_json === "string" 
              ? JSON.parse(evt.payload_json) 
              : evt.payload_json;
            ip = payload?.ip || "unknown";
          } catch (e) {}
          return {
            time: new Date(evt.created_at).getTime(),
            ip
          };
        });

        const serverTime = data.serverTime || clientNow;

        // For each of the 89 bins, determine the unique IPs active in [binTime - 40000, binTime]
        bins.forEach((bin: any, binIdx: number) => {
          let binTime = 0;
          if (binIdx < 29) {
            // Minute bin representing historical trend
            binTime = serverTime - (29 - binIdx) * 60 * 1000;
          } else {
            // Second bin representing live update
            const secIdx = binIdx - 29;
            binTime = serverTime - (59 - secIdx) * 1000;
          }

          // Count distinct visitor IPs in the 40-second active window prior to binTime
          const activeIps = new Set();
          events.forEach((evt: any) => {
            if (evt.time >= binTime - 40000 && evt.time <= binTime) {
              activeIps.add(evt.ip);
            }
          });
          bin.total_views = activeIps.size;
        });

        hourlyData = bins;
      }

      updateChartData();
    } catch (err) {
      console.error("Failed to poll live stats:", err);
    }
  }

  // Poll database every 1 second (1000ms) for true real-time feedback
  setInterval(pollLiveStats, 1000);
</script>

