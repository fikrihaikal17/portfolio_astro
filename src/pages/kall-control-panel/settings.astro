---
export const prerender = false;

import AdminShell from "@/components/admin/AdminShell.astro";
import { ensureAdminOrRedirect } from "@/lib/admin/page-helpers";
import { formatDateTime, formatSettingKey } from "@/lib/admin/view-formatters";
import {
  getAllSettings,
  logAdminEvent,
  upsertSetting,
} from "@/lib/admin/repository";

const { currentAdmin, response } = await ensureAdminOrRedirect(Astro);
if (response) {
  return response;
}
const admin = currentAdmin!;

let noticeMessage = "";
let errorMessage = "";

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const action = String(formData.get("action") ?? "");

  try {
    if (action === "save-setting") {
      const key = String(formData.get("setting_key") ?? "").trim();
      const value = String(formData.get("setting_value") ?? "").trim();
      const valueTypeRaw = String(formData.get("value_type") ?? "string").trim();
      const allowedTypes = ["string", "number", "boolean", "json"] as const;
      const valueType = allowedTypes.includes(valueTypeRaw as (typeof allowedTypes)[number])
        ? (valueTypeRaw as (typeof allowedTypes)[number])
        : "string";

      if (!key) {
        throw new Error("Setting key wajib diisi.");
      }

      if (valueType === "json") {
        JSON.parse(value || "{}");
      }

      await upsertSetting(key, value, valueType, admin.id);
      await logAdminEvent(
        "setting_updated",
        "admin-settings",
        `Setting ${key} disimpan oleh ${admin.username}`,
        "info",
        { key, valueType },
        admin.id
      );
      noticeMessage = "Setting berhasil disimpan.";
    }
  } catch (error) {
    errorMessage = error instanceof Error ? error.message : "Terjadi kesalahan tak terduga.";
    await logAdminEvent(
      "admin_action_failed",
      "admin-settings",
      `Aksi settings gagal: ${errorMessage}`,
      "error",
      { action },
      admin.id
    );
  }
}

const settings = await getAllSettings();
---

<AdminShell
  currentAdmin={admin}
  pageTitle="Website Settings"
  pageDescription="Kelola key-value global website lewat URL halaman khusus settings."
  activePath="/kall-control-panel/settings"
  noticeMessage={noticeMessage}
  errorMessage={errorMessage}
>
  <section class="section">
    <h3>Website Settings (MySQL)</h3>
    <p class="sub">Tambah atau ubah key-value setting website dari panel admin.</p>

    <form method="post">
      <input type="hidden" name="action" value="save-setting" />
      <div class="form-grid">
        <div class="form-group">
          <label for="setting_key">Nama Setting</label>
          <input id="setting_key" name="setting_key" placeholder="Contoh: site_title" required />
        </div>
        <div class="form-group">
          <label for="value_type">Tipe Data</label>
          <select id="value_type" name="value_type">
            <option value="string">Teks (string)</option>
            <option value="number">Angka (number)</option>
            <option value="boolean">Ya/Tidak (boolean)</option>
            <option value="json">JSON (objek)</option>
          </select>
        </div>
        <div class="form-group full">
          <label for="setting_value">Nilai Setting</label>
          <textarea id="setting_value" name="setting_value" placeholder='Contoh nilai JSON: {"heroTitle":"Hello"}' required></textarea>
        </div>
      </div>
      <div class="actions">
        <button type="submit">Simpan Setting</button>
      </div>
    </form>

    <div class="tableWrap">
      <table>
        <thead>
          <tr>
            <th>Nama Setting</th>
            <th>Value</th>
            <th>Updated</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          {settings.length === 0 ? (
            <tr>
              <td colspan="4" class="muted">Belum ada setting tersimpan.</td>
            </tr>
          ) : (
            settings.map((setting) => (
              <tr>
                <td style="font-weight: 600; color: var(--white);">{formatSettingKey(setting.setting_key)}</td>
                <td>{setting.setting_value}</td>
                <td>{formatDateTime(setting.updated_at)}</td>
                <td>
                  <div class="action-wrap">
                    <button type="button" class="kebab-btn" aria-label="Aksi">⋮</button>
                    <div class="kebab-dropdown">
                      <button
                        type="button"
                        class="kebab-item edit-setting-btn"
                        data-key={setting.setting_key}
                        data-type={setting.value_type}
                        data-value={setting.setting_value}
                      >✏️ Edit</button>
                    </div>
                  </div>
                </td>
              </tr>
            ))
          )}
        </tbody>
      </table>
    </div>
  </section>
</AdminShell>

<script>
  // Kebab dropdown toggle
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    const trigger = target.closest(".kebab-btn");
    const wrap = target.closest(".action-wrap");
    document.querySelectorAll(".action-wrap.open").forEach((el) => {
      if (el !== wrap) el.classList.remove("open");
    });
    if (trigger && wrap) wrap.classList.toggle("open");
  });

  const editButtons = document.querySelectorAll(".edit-setting-btn");
  const keyInput = document.getElementById("setting_key") as HTMLInputElement;
  const typeSelect = document.getElementById("value_type") as HTMLSelectElement;
  const valueInput = document.getElementById("setting_value") as HTMLTextAreaElement;

  editButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const key = btn.getAttribute("data-key") ?? "";
      const type = btn.getAttribute("data-type") ?? "string";
      const value = btn.getAttribute("data-value") ?? "";

      if (keyInput) keyInput.value = key;
      if (typeSelect) typeSelect.value = type;
      if (valueInput) valueInput.value = value;

      btn.closest(".action-wrap")?.classList.remove("open");
      keyInput?.scrollIntoView({ behavior: "smooth", block: "center" });
    });
  });
</script>
