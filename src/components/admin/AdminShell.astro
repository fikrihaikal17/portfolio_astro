---
import "@/styles/admin-shell.css";

interface AdminUser {
  username: string;
  role: string;
}

interface Props {
  currentAdmin: AdminUser;
  pageTitle: string;
  pageDescription: string;
  activePath: string;
  noticeMessage?: string;
  errorMessage?: string;
}

const {
  currentAdmin,
  pageTitle,
  pageDescription,
  activePath,
  noticeMessage = "",
  errorMessage = "",
} = Astro.props as Props;

const profileInitial = (currentAdmin.username?.trim()?.charAt(0) || "U").toUpperCase();

const navItems = [
  {
    group: "Menu Utama",
    items: [
      { href: "/admin", label: "Dashboard Utama" },
      { href: "/admin/monitoring/views", label: "Monitoring - Views Per Hari" },
      { href: "/admin/monitoring/content", label: "Monitoring - Konten Web Public" },
    ],
  },
  {
    group: "Manajemen Konten",
    items: [
      { href: "/admin/cms", label: "CMS Pages" },
      { href: "/admin/settings", label: "Website Settings" },
    ],
  },
  {
    group: "Operasional",
    items: [
      { href: "/admin/events", label: "Monitoring Events" },
      { href: "/admin/sessions", label: "Active Sessions" },
    ],
  },
];
---

<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle} - Superadmin</title>
  </head>
  <body>
    <div class="layout">
      <aside class="sidebar">
        <div class="brand">
          <h1>Superadmin Panel</h1>
          <p>Control Center</p>
        </div>

        <nav class="sidebar-nav" aria-label="Menu sidebar admin">
          {
            navItems.map((group) => (
              <>
                <p class="nav-group">{group.group}</p>
                {group.items.map((item) => (
                  <a class={`sidebar-link ${activePath === item.href ? "primary" : ""}`.trim()} href={item.href}>
                    {item.label}
                  </a>
                ))}
              </>
            ))
          }
        </nav>

        <details class="profile-menu">
          <summary class="profile-trigger" aria-label="Buka menu profil">
            <span class="profile-avatar" aria-hidden="true">{profileInitial}</span>
            <span class="profile-text">
              <strong>{currentAdmin.username}</strong>
              <span>{currentAdmin.role}</span>
            </span>
            <span class="profile-chevron" aria-hidden="true">▾</span>
          </summary>

          <div class="profile-dropdown">
            <form method="post" action="/admin/logout">
              <button class="logout" type="submit">Logout</button>
            </form>
          </div>
        </details>
      </aside>

      <main class="content">
        <header class="header">
          <div>
            <h2>{pageTitle}</h2>
            <p>{pageDescription}</p>
          </div>
        </header>

        {noticeMessage && <div class="status ok">{noticeMessage}</div>}
        {errorMessage && <div class="status err">{errorMessage}</div>}

        <slot />
      </main>
    </div>
  </body>
</html>
