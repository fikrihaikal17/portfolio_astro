---
import { getAllProjects } from "@/lib/admin/repository";

interface Project {
  title: string;
  link: string;
  preview: string;
  statusKey: string;
  statusText: string;
}

let projects: Project[] = [];
try {
  const dbProjects = await getAllProjects();
  projects = dbProjects.map(p => ({
    title: p.title,
    link: p.link,
    preview: p.preview,
    statusKey: p.status_key,
    statusText: p.status_text
  }));
} catch (e) {
  console.error("Failed to load projects from DB:", e);
}
---


<section
  id="projects"
  class="py-12 border-t border-[var(--border-subtle)] text-[var(--white)]"
  data-scroll-reveal
  data-aos="fade-up"
  data-theme-animate
>
  <div class="max-w-5xl mx-auto">
    <h2 class="text-lg text-[var(--sec)] mb-2 shiny-sec" data-i18n="projects.kicker"
      >My work</h2
    >
    <h3 class="text-4xl md:text-5xl font-medium mb-8" data-i18n="projects.title"
      >Projects</h3
    >

    <div class="grid grid-cols-2 gap-4 md:gap-8">
      {
        projects.map((project, index) => (
          <div
            class="group"
            data-aos="zoom-in-up"
            data-aos-delay={(80 + index * 70).toString()}
          >
            <a
              href={project.preview}
              target="_blank"
              rel="noopener noreferrer"
              class="block"
            >
              <div class="rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow duration-300 mb-4">
                <div
                  class="w-full h-28 sm:h-40 md:h-72 relative overflow-hidden group-hover:scale-105 transition-transform duration-300 bg-[linear-gradient(145deg,color-mix(in_srgb,var(--sec)_38%,transparent),color-mix(in_srgb,var(--component-bg)_78%,transparent))]"
                  aria-label={`Placeholder preview for ${project.title}`}
                >
                  <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_20%,rgba(255,255,255,0.18),transparent_45%)]"></div>
                  <div class="absolute inset-x-2 bottom-2 md:inset-x-4 md:bottom-4 px-2 py-1 md:px-3 md:py-2 rounded-lg border border-[var(--white-icon-tr)] bg-[color-mix(in_srgb,var(--component-bg)_86%,transparent)] text-[var(--white-icon)] text-[9px] md:text-xs tracking-[0.08em] uppercase text-center">
                    <span class="hidden sm:inline" data-translate>Preview image pending update</span>
                    <span class="inline sm:hidden" data-translate>Pending Update</span>
                  </div>
                </div>
              </div>
              <div class="flex flex-col sm:flex-row sm:items-center px-1 md:px-3 gap-1 md:gap-3">
                <div class="flex-grow">
                  <h4 class="text-sm sm:text-base md:text-2xl font-semibold leading-tight" data-translate>{project.title}</h4>
                  <span
                    class="block py-0.5 text-xs sm:text-sm text-[var(--white-icon)]"
                    data-i18n={project.statusKey}
                    data-translate
                  >
                    {project.statusText}
                  </span>
                </div>
                <div class="flex gap-1.5 sm:gap-2 mt-1.5 sm:mt-0">
                  <a
                    target="_blank"
                    href={project.link}
                    aria-label="GitHub"
                    class="size-8 sm:size-10 md:size-14 flex justify-center items-center text-[var(--white-icon)] hover:text-[var(--white)] transition duration-300 ease-in-out border border-1 border-[var(--white-icon-tr)] p-1.5 sm:p-2 md:p-3 rounded-lg md:rounded-xl bg-[var(--component-bg)] hover:bg-[var(--white-icon-tr)]"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      class="size-4 sm:size-5 md:size-7"
                    >
                      <path d="M24 12L18.3431 17.6569L16.9289 16.2426L21.1716 12L16.9289 7.75736L18.3431 6.34315L24 12ZM2.82843 12L7.07107 16.2426L5.65685 17.6569L0 12L5.65685 6.34315L7.07107 7.75736L2.82843 12ZM9.78845 21H7.66009L14.2116 3H16.3399L9.78845 21Z" />
                    </svg>
                  </a>
                  <a
                    target="_blank"
                    href={project.preview}
                    aria-label="Preview"
                    class="size-8 sm:size-10 md:size-14 flex justify-center items-center text-[var(--white-icon)] hover:text-[var(--white)] transition duration-300 ease-in-out border border-1 border-[var(--white-icon-tr)] p-1.5 sm:p-2 md:p-3 rounded-lg md:rounded-xl bg-[var(--component-bg)] hover:bg-[var(--white-icon-tr)]"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      class="size-4 sm:size-5 md:size-7"
                    >
                      <path d="M16.0037 9.41421L7.39712 18.0208L5.98291 16.6066L14.5895 8H7.00373V6H18.0037V17H16.0037V9.41421Z" />
                    </svg>
                  </a>
                </div>
              </div>
            </a>
          </div>
        ))
      }
    </div>
    <a
      target="_blank"
      href="https://github.com/fikrihaikal17"
      aria-label="GitHub"
      class="w-full flex items-center justify-center gap-2 mt-9 text-[var(--white-icon)] hover:text-[var(--white)] transition duration-300 ease-in-out border border-[var(--white-icon-tr)] p-3 rounded-full bg-[var(--component-bg)] hover:bg-[var(--white-icon-tr)] hover:scale-105"
    >
      <span class="md:text-lg text-md" data-i18n="projects.moreOn"
        >More projects on</span
      >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
        class="size-6"
      >
        <path
          d="M12.001 2C6.47598 2 2.00098 6.475 2.00098 12C2.00098 16.425 4.86348 20.1625 8.83848 21.4875C9.33848 21.575 9.52598 21.275 9.52598 21.0125C9.52598 20.775 9.51348 19.9875 9.51348 19.15C7.00098 19.6125 6.35098 18.5375 6.15098 17.975C6.03848 17.6875 5.55098 16.8 5.12598 16.5625C4.77598 16.375 4.27598 15.9125 5.11348 15.9C5.90098 15.8875 6.46348 16.625 6.65098 16.925C7.55098 18.4375 8.98848 18.0125 9.56348 17.75C9.65098 17.1 9.91348 16.6625 10.201 16.4125C7.97598 16.1625 5.65098 15.3 5.65098 11.475C5.65098 10.3875 6.03848 9.4875 6.67598 8.7875C6.57598 8.5375 6.22598 7.5125 6.77598 6.1375C6.77598 6.1375 7.61348 5.875 9.52598 7.1625C10.326 6.9375 11.176 6.825 12.026 6.825C12.876 6.825 13.726 6.9375 14.526 7.1625C16.4385 5.8625 17.276 6.1375 17.276 6.1375C17.826 7.5125 17.476 8.5375 17.376 8.7875C18.0135 9.4875 18.401 10.375 18.401 11.475C18.401 15.3125 16.0635 16.1625 13.8385 16.4125C14.201 16.725 14.5135 17.325 14.5135 18.2625C14.5135 19.6 14.501 20.675 14.501 21.0125C14.501 21.275 14.6885 21.5875 15.1885 21.4875C19.259 20.1133 21.9999 16.2963 22.001 12C22.001 6.475 17.526 2 12.001 2Z"
        ></path>
      </svg>
    </a>
  </div>
</section>
