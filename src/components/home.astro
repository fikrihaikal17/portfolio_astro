---
import LetterGlitch from "../React/LetterGlitch.tsx";
import LogoWall from "../components/logoWall.astro";
import SkillsList from "../React/SkillsList.tsx";
import HeroThreeBackground from "../React/HeroThreeBackground.tsx";
import HeroGsapController from "../React/HeroGsapController.tsx";
import { getSettingValue } from "@/lib/admin/repository";

const ownerName = await getSettingValue("owner_name", "Muhammad Fikri Haikal");
---

<section
  class="text-[var(--white)] mt-12 md:mt-0 relative isolate overflow-hidden"
  id="home"
  data-scroll-reveal
  data-aos="fade-up"
  data-aos-delay="60"
  data-theme-animate
>
  <div class="home-three-wrap" aria-hidden="true">
    <HeroThreeBackground client:load />
  </div>

  <HeroGsapController client:load />

  <div class="max-w-5xl mx-auto space-y-8 md:py-36 pb-14 relative z-10">
    <div class="text-left space-y-4">
      <p
        class="home-hero-greeting"
        data-i18n="home.greeting"
        data-intro
      >
        Hi, I'm {ownerName}
      </p>
      <div
        class="home-hero-intro flex flex-col space-y-3 md:space-y-4"
      >
        <h1
          class="home-hero-title text-[var(--white)] text-4xl md:text-6xl font-medium text-pretty leading-none"
          data-intro
        >
          <span class="home-hero-title-line home-hero-title-line-a"><span data-i18n="home.roleLine1">Software</span></span><br /><span
            class="home-hero-title-line home-hero-title-line-b"
            ><span data-i18n="home.roleLine2">Engineer</span></span
          >
        </h1>
        <div class="home-hero-copy-block" data-intro>
          <p class="home-hero-tagline text-md md:text-2xl text-[var(--white-icon)]">
            <span data-i18n="home.taglinePrefix"
              >Transforming ideas into practical digital solutions powered by</span
            >
            <span class="text-[var(--sec)] shiny-sec" data-i18n="home.taglineHighlight"
              >backend, IoT, and cloud</span
            >
            <span data-i18n="home.taglineSuffix">expertise.</span>
          </p>

          <p class="home-hero-tech-label" data-i18n="home.hero.techLabel">Core stack</p>
          <div class="home-hero-tech-row" aria-label="Tech stack highlights">
            <span class="home-hero-tech">Laravel</span>
            <span class="home-hero-tech">PHP</span>
            <span class="home-hero-tech">JavaScript</span>
            <span class="home-hero-tech">Python</span>
            <span class="home-hero-tech">IoT</span>
          </div>

        </div>
      </div>
      <div class="home-hero-meta pt-3 md:pt-6" data-intro>
        <div class="home-hero-socials" data-theme-animate>
          <p class="home-hero-socials-label" data-i18n="home.hero.connectLabel">Connect</p>
          <div class="home-hero-socials-row">
          <a
            target="_blank"
            href="https://github.com/fikrihaikal17"
            aria-label="GitHub"
            class="home-social-link"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="size-8"
            >
              <path
                d="M12.001 2C6.47598 2 2.00098 6.475 2.00098 12C2.00098 16.425 4.86348 20.1625 8.83848 21.4875C9.33848 21.575 9.52598 21.275 9.52598 21.0125C9.52598 20.775 9.51348 19.9875 9.51348 19.15C7.00098 19.6125 6.35098 18.5375 6.15098 17.975C6.03848 17.6875 5.55098 16.8 5.12598 16.5625C4.77598 16.375 4.27598 15.9125 5.11348 15.9C5.90098 15.8875 6.46348 16.625 6.65098 16.925C7.55098 18.4375 8.98848 18.0125 9.56348 17.75C9.65098 17.1 9.91348 16.6625 10.201 16.4125C7.97598 16.1625 5.65098 15.3 5.65098 11.475C5.65098 10.3875 6.03848 9.4875 6.67598 8.7875C6.57598 8.5375 6.22598 7.5125 6.77598 6.1375C6.77598 6.1375 7.61348 5.875 9.52598 7.1625C10.326 6.9375 11.176 6.825 12.026 6.825C12.876 6.825 13.726 6.9375 14.526 7.1625C16.4385 5.8625 17.276 6.1375 17.276 6.1375C17.826 7.5125 17.476 8.5375 17.376 8.7875C18.0135 9.4875 18.401 10.375 18.401 11.475C18.401 15.3125 16.0635 16.1625 13.8385 16.4125C14.201 16.725 14.5135 17.325 14.5135 18.2625C14.5135 19.6 14.501 20.675 14.501 21.0125C14.501 21.275 14.6885 21.5875 15.1885 21.4875C19.259 20.1133 21.9999 16.2963 22.001 12C22.001 6.475 17.526 2 12.001 2Z"
              ></path>
            </svg>
          </a>
          <a
            target="_blank"
            href="https://www.linkedin.com/in/fikriihaikal"
            aria-label="LinkedIn"
            class="home-social-link"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="size-8"
            >
              <path
                d="M18.3362 18.339H15.6707V14.1622C15.6707 13.1662 15.6505 11.8845 14.2817 11.8845C12.892 11.8845 12.6797 12.9683 12.6797 14.0887V18.339H10.0142V9.75H12.5747V10.9207H12.6092C12.967 10.2457 13.837 9.53325 15.1367 9.53325C17.8375 9.53325 18.337 11.3108 18.337 13.6245V18.339H18.3362ZM7.00373 8.57475C6.14573 8.57475 5.45648 7.88025 5.45648 7.026C5.45648 6.1725 6.14648 5.47875 7.00373 5.47875C7.85873 5.47875 8.55173 6.1725 8.55173 7.026C8.55173 7.88025 7.85798 8.57475 7.00373 8.57475ZM8.34023 18.339H5.66723V9.75H8.34023V18.339ZM19.6697 3H4.32923C3.59498 3 3.00098 3.5805 3.00098 4.29675V19.7033C3.00098 20.4202 3.59498 21 4.32923 21H19.6675C20.401 21 21.001 20.4202 21.001 19.7033V4.29675C21.001 3.5805 20.401 3 19.6675 3H19.6697Z"
              ></path>
            </svg>
          </a>
          <a
            target="_blank"
            rel="noopener noreferrer"
            href="https://www.instagram.com/fikrii_haikalll17/"
            aria-label="Instagram"
            class="home-social-link"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="size-8"
            >
              <path
                d="M7.75 2C4.57436 2 2 4.57436 2 7.75V16.25C2 19.4256 4.57436 22 7.75 22H16.25C19.4256 22 22 19.4256 22 16.25V7.75C22 4.57436 19.4256 2 16.25 2H7.75ZM20 7.75V16.25C20 18.3211 18.3211 20 16.25 20H7.75C5.67893 20 4 18.3211 4 16.25V7.75C4 5.67893 5.67893 4 7.75 4H16.25C18.3211 4 20 5.67893 20 7.75ZM12 7C9.23858 7 7 9.23858 7 12C7 14.7614 9.23858 17 12 17C14.7614 17 17 14.7614 17 12C17 9.23858 14.7614 7 12 7ZM12 9C13.6569 9 15 10.3431 15 12C15 13.6569 13.6569 15 12 15C10.3431 15 9 13.6569 9 12C9 10.3431 10.3431 9 12 9ZM17.5 6.5C16.9477 6.5 16.5 6.94772 16.5 7.5C16.5 8.05228 16.9477 8.5 17.5 8.5C18.0523 8.5 18.5 8.05228 18.5 7.5C18.5 6.94772 18.0523 6.5 17.5 6.5Z"
              ></path>
            </svg>
          </a>
          <a
            target="_blank"
            href="https://mail.google.com/mail/?view=cm&fs=1&to=fikrihaikal170308@gmail.com&su=Hey%20Muhammad%20Fikri%20Haikal!"
            aria-label="Email"
            class="home-social-link"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="2.1em"
              height="2.1em"
              viewBox="0 0 24 24"
            >
              <path
                fill="currentColor"
                d="m18.73 5.41l-1.28 1L12 10.46L6.55 6.37l-1.28-1A2 2 0 0 0 2 7.05v11.59A1.36 1.36 0 0 0 3.36 20h3.19v-7.72L12 16.37l5.45-4.09V20h3.19A1.36 1.36 0 0 0 22 18.64V7.05a2 2 0 0 0-3.27-1.64"
              ></path>
            </svg>
          </a>
          </div>
        </div>

        <article class="home-hero-signal" data-theme-animate>
          <p class="home-hero-signal-title" data-i18n="home.hero.signalTitle">Internship Snapshot</p>
          <p class="home-hero-signal-text" data-i18n="home.hero.signalText">
            Software Engineer Intern at Sakata Innovation Center, developing Niskala and KWS web applications while building IoT prototypes.
          </p>
        </article>

        <article class="home-hero-status" data-theme-animate>
          <div class="home-hero-status-copy">
            <div class="home-hero-status-head">
              <span class="home-hero-status-dot" aria-hidden="true"></span>
              <p class="home-hero-status-title" data-i18n="home.hero.statusTitle">Current Focus</p>
            </div>
            <p class="home-hero-status-item" data-i18n="home.hero.statusItem1">
              Building backend and frontend solutions with real-world use cases in web and IoT.
            </p>
            <p class="home-hero-status-item" data-i18n="home.hero.statusItem2">
              Open to internship and collaborative opportunities in software development.
            </p>
            <div class="home-hero-status-pills">
              <span class="home-hero-pill" data-i18n="home.hero.pill1">Backend Specialist</span>
              <span class="home-hero-pill" data-i18n="home.hero.pill2">IoT & Cloud</span>
              <span class="home-hero-pill" data-i18n="home.hero.pill3">AI/ML Explorer</span>
            </div>
          </div>

          <div class="home-hero-status-side" data-intro>
            <a href="#projects" class="home-hero-action home-hero-action-primary home-hero-action-main">
              <span data-i18n="home.hero.ctaProjects">View Projects</span>
            </a>
            <a
              href="https://drive.google.com/uc?export=download&id=1X_FvqhSTDlsd4mklxjFlz5YI8X1IDQJi"
              target="_blank"
              rel="noopener noreferrer"
              class="home-hero-action home-hero-action-secondary"
            >
              <span data-i18n="home.hero.ctaDownloadCv">Download CV</span>
            </a>
          </div>
        </article>
      </div>

      <a
        href="#expertise"
        class="home-scroll-cue"
        aria-label="Scroll down to expertise"
        data-intro
      >
        <span class="home-scroll-cue-shell" aria-hidden="true">
          <span class="home-scroll-cue-wheel"></span>
          <span class="home-scroll-cue-arrow"></span>
        </span>
      </a>
    </div>

    <LogoWall />

    <div
      id="experience"
      class="flex flex-col lg:flex-row items-start gap-8 mt-3 md:mt-5 pt-5 md:pt-8 border-t border-[var(--border-subtle)] scroll-mt-36"
    >
      <SkillsList client:visible />
      <div class="home-focus-wrap w-full lg:max-w-[36rem] pt-3 md:pt-9 lg:ml-6" data-intro>
        <article class="home-focus-panel">
          <div class="home-focus-head">
            <div class="home-focus-copy">
              <p class="home-focus-kicker" data-i18n="home.focus.kicker">Build Focus</p>
              <h4 class="home-focus-title" data-i18n="home.focus.title">
                Crafting scalable interfaces with clean interaction flow.
              </h4>
              <p class="home-focus-description" data-i18n="home.focus.description">
                From concept to deployment, every detail is tuned for speed, clarity, and user confidence.
              </p>
            </div>

            <div class="home-focus-visual" aria-hidden="true">
              <div class="home-focus-orbit">
                <span class="home-focus-orbit-ring home-focus-orbit-ring-a"></span>
                <span class="home-focus-orbit-ring home-focus-orbit-ring-b"></span>
                <span class="home-focus-orbit-core"></span>
                <span class="home-focus-orbit-node home-focus-orbit-node-a"></span>
                <span class="home-focus-orbit-node home-focus-orbit-node-b"></span>
              </div>

              <div class="home-focus-glitch">
                <LetterGlitch
                  client:visible
                  glitchColors={["#7256BF", "#8A74DA", "#4E3B84"]}
                  glitchSpeed={33}
                  centerVignette={false}
                  outerVignette={false}
                  smooth={true}
                />
              </div>
            </div>
          </div>

          <div class="home-focus-flow">
            <p class="home-focus-flow-title" data-i18n="home.focus.flow.title">Workflow Pulse</p>
            <div class="home-focus-flow-track" aria-hidden="true"></div>
            <div class="home-focus-flow-steps">
              <div class="home-focus-flow-step">
                <span class="home-focus-flow-dot"></span>
                <p class="home-focus-flow-label" data-i18n="home.focus.flow.step.1">Discover</p>
              </div>
              <div class="home-focus-flow-step">
                <span class="home-focus-flow-dot"></span>
                <p class="home-focus-flow-label" data-i18n="home.focus.flow.step.2">Build</p>
              </div>
              <div class="home-focus-flow-step">
                <span class="home-focus-flow-dot"></span>
                <p class="home-focus-flow-label" data-i18n="home.focus.flow.step.3">Ship</p>
              </div>
            </div>
          </div>

          <div class="home-focus-tags">
            <span class="home-focus-tag" data-i18n="home.focus.tag.1">Performance-first</span>
            <span class="home-focus-tag" data-i18n="home.focus.tag.2">Design systems</span>
            <span class="home-focus-tag" data-i18n="home.focus.tag.3">Accessible UX</span>
          </div>
        </article>

        <div class="home-focus-grid">
          <article class="home-focus-mini">
            <p class="home-focus-mini-label" data-i18n="home.focus.metric.1.label">Delivery mode</p>
            <p class="home-focus-mini-value" data-i18n="home.focus.metric.1.value">Rapid & iterative</p>
          </article>
          <article class="home-focus-mini">
            <p class="home-focus-mini-label" data-i18n="home.focus.metric.2.label">Code quality</p>
            <p class="home-focus-mini-value" data-i18n="home.focus.metric.2.value">Readable, maintainable</p>
          </article>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .home-three-wrap {
    position: absolute;
    inset: -14% -9% -20%;
    z-index: 0;
    pointer-events: none;
    opacity: 0.78;
    filter: saturate(1.08) blur(0.2px);
  }

  .hero-three-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }

  :root[data-theme="light"] .home-three-wrap {
    opacity: 0.34;
    mix-blend-mode: multiply;
    filter: saturate(0.9) blur(0.28px);
  }

  .shiny-sec {
    background: linear-gradient(135deg, #a476ff 25%, #eee5ff 50%, #a476ff 75%);
    background-size: 400% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: shine 3s linear infinite;
  }

  @keyframes shine {
    0% {
      background-position: 100% 50%;
    }
    30%,
    70% {
      background-position: 0% 50%;
    }
  }

  .home-hero-intro {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    row-gap: 0.62rem;
    position: relative;
    overflow: hidden;
    border-radius: 1.52rem 1.38rem 1.6rem 1.32rem;
    border: 1px solid color-mix(in srgb, var(--white) 28%, var(--border-subtle) 72%);
    padding: 0.52rem 0.62rem 0.78rem;
    background: linear-gradient(
      154deg,
      rgba(255, 255, 255, 0.13) 0%,
      rgba(255, 255, 255, 0.06) 42%,
      rgba(255, 255, 255, 0.02) 100%
    );
    background-color: rgba(255, 255, 255, 0.02);
    box-shadow:
      0 18px 38px rgba(3, 8, 20, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.3),
      inset 0 -10px 20px rgba(7, 13, 26, 0.28);
    backdrop-filter: blur(22px) saturate(136%) contrast(101%);
    -webkit-backdrop-filter: blur(22px) saturate(136%) contrast(101%);
  }

  .home-hero-intro::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(
      74% 108% at 10% -10%,
      rgba(255, 255, 255, 0.24),
      transparent 56%
    );
    opacity: 0.2;
    transform: none;
    animation: none;
  }

  .home-hero-intro::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.11) 0%,
      rgba(255, 255, 255, 0.03) 34%,
      transparent 66%
    );
    animation: none;
  }

  .home-hero-title {
    position: relative;
    z-index: 2;
    letter-spacing: -0.03em;
    line-height: 1.02;
    padding-bottom: 0.12em;
    text-wrap: balance;
    text-shadow: 0 12px 28px rgba(0, 0, 0, 0.22);
  }

  .home-hero-title-line {
    position: relative;
    display: inline-block;
    line-height: 1.04;
    padding-bottom: 0.06em;
    background: linear-gradient(
      110deg,
      #ffffff 6%,
      #c6dbff 24%,
      #61d7ff 42%,
      #93b8ff 60%,
      #a4f0ff 76%,
      #ffffff 94%
    );
    background-size: 280% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    -webkit-text-stroke: 1px rgba(147, 194, 255, 0.34);
    text-shadow:
      0 12px 28px rgba(0, 0, 0, 0.3),
      0 0 22px rgba(107, 201, 255, 0.38);
    animation:
      home-hero-title-breathe 2.8s ease-in-out infinite,
      home-hero-title-sheen 3.6s linear infinite,
      home-hero-title-tint 2.4s ease-in-out infinite;
  }

  .home-hero-title-line-b {
    animation-delay: 0.35s, 0.45s, 0.4s;
  }

  @supports not ((-webkit-background-clip: text) or (background-clip: text)) {
    .home-hero-title-line {
      color: #e7efff;
      -webkit-text-fill-color: initial;
      background: none;
      animation: home-hero-title-breathe 2.8s ease-in-out infinite;
    }
  }

  @keyframes home-hero-title-breathe {
    0%,
    100% {
      transform: translateY(0);
      filter: brightness(1);
    }
    50% {
      transform: translateY(-0.02em);
      filter: brightness(1.08);
    }
  }

  @keyframes home-hero-title-sheen {
    0%,
    100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  @keyframes home-hero-title-tint {
    0%,
    100% {
      filter: saturate(1) brightness(1);
    }
    50% {
      filter: saturate(1.2) brightness(1.18);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-hero-title-line {
      animation:
        home-hero-title-breathe 6s ease-in-out infinite,
        home-hero-title-sheen 14s linear infinite,
        home-hero-title-tint 10s ease-in-out infinite;
    }
  }

  .home-hero-greeting {
    position: relative;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 0.56rem;
    width: fit-content;
    padding: 0.44rem 0.94rem;
    border-radius: 9999px;
    border: 1px solid color-mix(in srgb, var(--white) 34%, var(--sec) 66%);
    color: color-mix(in srgb, var(--white) 94%, var(--sec) 6%);
    font-size: clamp(1.06rem, 1.68vw, 1.42rem);
    font-weight: 700;
    letter-spacing: 0.012em;
    line-height: 1.1;
    background: linear-gradient(
      148deg,
      rgba(255, 255, 255, 0.2) 0%,
      rgba(255, 255, 255, 0.09) 56%,
      rgba(255, 255, 255, 0.03) 100%
    );
    box-shadow:
      0 10px 24px rgba(2, 8, 20, 0.28),
      inset 0 1px 0 rgba(255, 255, 255, 0.28);
    text-shadow: 0 1px 0 rgba(0, 0, 0, 0.36);
  }

  .home-hero-greeting::before {
    content: "";
    width: 0.54rem;
    height: 0.54rem;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--sec) 72%, var(--white) 28%);
    box-shadow: 0 0 0.7rem color-mix(in srgb, var(--sec) 38%, transparent);
    flex: 0 0 auto;
  }

  :root[data-theme="light"] .home-hero-greeting {
    color: color-mix(in srgb, var(--white) 86%, black 14%);
    border-color: color-mix(in srgb, var(--sec) 40%, var(--border-subtle) 60%);
    background: linear-gradient(
      148deg,
      rgba(255, 255, 255, 0.98) 0%,
      rgba(255, 255, 255, 0.9) 56%,
      rgba(255, 255, 255, 0.82) 100%
    );
    box-shadow:
      0 8px 16px rgba(53, 69, 101, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.95);
    text-shadow: none;
  }

  .home-hero-copy-block {
    position: relative;
    z-index: 2;
    max-width: 39rem;
  }

  .home-hero-tagline {
    font-size: clamp(1.08rem, 2.2vw, 2rem);
    line-height: 1.26;
    text-wrap: pretty;
  }

  @media (min-width: 1024px) {
    .home-hero-intro {
      grid-template-columns: minmax(15.5rem, 0.92fr) minmax(0, 1.28fr);
      column-gap: 1.38rem;
      row-gap: 0;
      align-items: center;
    }

    .home-focus-wrap {
      padding-top: 3.35rem;
    }

    .home-hero-title {
      font-size: clamp(4.1rem, 5.15vw, 5.4rem);
      line-height: 1.02;
    }

    .home-hero-tagline {
      font-size: clamp(1.4rem, 2.1vw, 2.08rem);
      line-height: 1.24;
    }
  }

  .home-hero-tech-label {
    margin-top: 0.82rem;
    margin-bottom: 0.36rem;
    color: color-mix(in srgb, var(--sec) 72%, var(--white) 28%);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .home-hero-tech-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.38rem;
  }

  .home-hero-tech {
    border-radius: 9999px;
    border: 1px solid color-mix(in srgb, var(--white) 18%, var(--sec) 82%);
