# Public site URL (optional, used for provider metadata)
PUBLIC_SITE_URL=http://localhost:4321

# Database config (superadmin panel)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=portfolio_admin
DB_CONNECTION_LIMIT=10

# Admin session config
ADMIN_SESSION_COOKIE_NAME=superadmin_session
ADMIN_SESSION_TTL_HOURS=12

# Chatbot providers (fallback order: Groq -> OpenRouter -> Gemini -> Cloudflare)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_AI_MODEL=@cf/meta/llama-3.1-8b-instruct
